# Zettle OAuth2 Credentials — Account 1
ZETTLE_ACCOUNT1_CLIENT_ID=your_client_id_here
ZETTLE_ACCOUNT1_CLIENT_SECRET=your_client_secret_here
ZETTLE_ACCOUNT1_ARTIST_NAME=Artiest X

# Zettle OAuth2 Credentials — Account 2
ZETTLE_ACCOUNT2_CLIENT_ID=your_client_id_here
ZETTLE_ACCOUNT2_CLIENT_SECRET=your_client_secret_here
ZETTLE_ACCOUNT2_ARTIST_NAME=Artiest Y

# Notion Integration
NOTION_API_KEY=secret_your_notion_integration_token
NOTION_TRANSACTIONS_DB_ID=your_transactions_database_id
NOTION_SUMMARY_DB_ID=your_summary_database_id

# Logging
LOG_FILE=zettle_sync.log
LAST_SYNC_FILE=.last_sync
